# Public URL where the dashboard is hosted
AUTH_URL=https://code.example.com
NEXTAUTH_URL=https://code.example.com

# 32-byte random secret for HMAC session signing
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth 2.0 Client (Web application)
# Authorized redirect URI: https://code.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of allowed Google account emails
ALLOWED_EMAIL=you@example.com

# tmuxy backend URL (where the browser opens each session)
# Typically reachable on your private network or Tailnet
NEXT_PUBLIC_TMUXY_ORIGIN=http://localhost:9000
